# Environment Variables for QADM CLI
# Copy this file to .env and fill in your values

# AS400 Connection Credentials
AS400_USER=your_username
AS400_PASSWORD=your_password

# Optional: Override config file location
# QADMCLI_CONFIG=/path/to/connection.yaml

# Optional: jt400.jar location
# JT400_JAR=/path/to/jt400.jar
