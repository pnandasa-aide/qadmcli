# AS400 DB2 for i Connection Configuration
# Copy this file to connection.yaml and update with your settings

as400:
  # Hostname or IP address of the AS400 system
  host: "as400.company.com"
  
  # Authentication credentials
  # You can use environment variables with ${VAR} syntax
  user: "${AS400_USER}"
  password: "${AS400_PASSWORD}"
  
  # DRDA port (default: 8471)
  port: 8471
  
  # Use SSL connection (recommended)
  ssl: true
  
  # Database name (usually *LOCAL for AS400)
  database: "*LOCAL"

# MSSQL Connection Configuration (optional - for cross-database operations)
mssql:
  # Hostname or IP address of the MSSQL server
  host: "mssql.company.com"
  
  # Authentication credentials
  username: "${MSSQL_USER}"
  password: "${MSSQL_PASSWORD}"
  
  # MSSQL port (default: 1433)
  port: 1433
  
  # Default database
  database: "master"

# Default settings
defaults:
  # Default library/schema for operations
  library: "QGPL"
  
  # Default journal library
  journal_library: "QSYS2"
  
  # Default journal name (used when enabling journaling)
  journal_name: "QSQJRN"

# Logging configuration
logging:
  level: "INFO"
  format: "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
